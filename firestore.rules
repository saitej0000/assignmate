rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /* =========================
       COMMON HELPERS
    ========================== */
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    /* =========================
       USERS
    ========================== */
    match /users/{userId} {
      allow read: if isAuthenticated();

      allow create, delete: if isAuthenticated() && isOwner(userId);

      allow update: if isAuthenticated() && (
        isOwner(userId) ||
        (
          // Controlled peer update with upper bound protection
          request.resource.data.diff(resource.data)
            .affectedKeys()
            .hasOnly(['projects_completed']) &&
          request.resource.data.projects_completed ==
            resource.data.projects_completed + 1 &&
          // 🛡️ FIX: Upper bound to prevent abuse
          resource.data.projects_completed < 500
        )
      );

      match /fcm_tokens/{token} {
        allow read, write: if isAuthenticated() && isOwner(userId);
      }
    }

    /* =========================
       COMMUNITY POSTS
    ========================== */
    match /community_posts/{postId} {
      allow read: if isAuthenticated();

      allow create: if isAuthenticated()
        && request.resource.data.user_id == request.auth.uid;

      // 🛡️ FIX: Validate likes/comments_count increments properly
      allow update: if isAuthenticated() && (
        // Owner can update anything
        resource.data.user_id == request.auth.uid ||
        (
          // Non-owners: only likes and comments_count with validation
          request.resource.data.diff(resource.data)
            .affectedKeys()
            .hasOnly(['likes', 'comments_count']) &&
          // Likes must change by exactly +1 or -1
          (
            request.resource.data.likes == resource.data.likes + 1 ||
            request.resource.data.likes == resource.data.likes - 1
          ) &&
          // Likes cannot go negative
          request.resource.data.likes >= 0 &&
          // Comments count validation
          (
            !request.resource.data.diff(resource.data).affectedKeys().hasAny(['comments_count']) ||
            (
              (request.resource.data.comments_count == resource.data.comments_count + 1 ||
               request.resource.data.comments_count == resource.data.comments_count - 1) &&
              request.resource.data.comments_count >= 0
            )
          )
        )
      );

      allow delete: if isAuthenticated()
        && resource.data.user_id == request.auth.uid;

      match /comments/{commentId} {
        allow read: if isAuthenticated();

        allow create: if isAuthenticated()
          && request.resource.data.user_id == request.auth.uid;

        // 🛡️ FIX: Explicit deny for update (prevent future accidental exposure)
        allow update: if false;

        allow delete: if isAuthenticated() && (
          resource.data.user_id == request.auth.uid ||
          get(/databases/$(database)/documents/community_posts/$(postId))
            .data.user_id == request.auth.uid
        );
      }
    }

    /* =========================
       CHATS
    ========================== */
    match /chats/{chatId} {

      // Chat participant check (parent document)
      function isChatParticipant() {
        return request.auth.uid in resource.data.participants ||
               resource.data.poster_id == request.auth.uid ||
               resource.data.writer_id == request.auth.uid;
      }

      // Subcollection-safe participant check
      function isParentChatParticipant() {
        let chat = get(
          /databases/$(database)/documents/chats/$(chatId)
        ).data;

        return request.auth.uid in chat.participants ||
               chat.poster_id == request.auth.uid ||
               chat.writer_id == request.auth.uid;
      }

      /* ---- Chat document ---- */
      allow create: if isAuthenticated() && (
        request.resource.data.poster_id == request.auth.uid ||
        request.resource.data.writer_id == request.auth.uid
      );

      allow read: if isAuthenticated() && isChatParticipant();

      // 🛡️ FIX: Restrict chat updates to safe fields only (prevent participant hijacking)
      allow update: if isAuthenticated() && isChatParticipant() &&
        request.resource.data.diff(resource.data)
          .affectedKeys()
          .hasOnly(['last_message', 'last_message_at', 'updated_at', 'unread_count']);

      /* =========================
         CHAT MESSAGES
      ========================== */
      match /messages/{messageId} {

        // Read: only chat members
        allow read: if isAuthenticated() && isParentChatParticipant();

        // 🛡️ FIX: Remove system sender spoofing - only real user can send
        allow create: if isAuthenticated()
          && isParentChatParticipant()
          && request.resource.data.sender_id == request.auth.uid;

        // Update: read receipts, offer status, etc. - restrict fields
        allow update: if isAuthenticated() && isParentChatParticipant() &&
          request.resource.data.diff(resource.data)
            .affectedKeys()
            .hasOnly(['read', 'read_at', 'status']);

        // DELETE (only sender can delete their own messages)
        allow delete: if isAuthenticated()
          && isParentChatParticipant()
          && request.auth.uid == resource.data.sender_id;
      }

      /* =========================
         CHAT FILE METADATA
      ========================== */
      match /files/{fileId} {
        allow read, create: if isAuthenticated() && isParentChatParticipant();
        // 🛡️ FIX: Add delete rule for file cleanup
        allow delete: if isAuthenticated() && isParentChatParticipant();
      }
    }

    /* =========================
       ORDERS / PROJECTS
    ========================== */
    match /orders/{orderId} {
      // For read and update: check existing document data
      allow read, update: if isAuthenticated() && (
        request.auth.uid == resource.data.student_id ||
        request.auth.uid == resource.data.poster_id ||
        request.auth.uid == resource.data.writer_id ||
        request.auth.uid in resource.data.participants
      );
      
      // 🛡️ FIX: Lock down order creation - creator must be poster, limit participants
      allow create: if isAuthenticated() && (
        request.auth.uid == request.resource.data.poster_id &&
        // Prevent dragging random users - participants max 3
        request.resource.data.participants.size() <= 3 &&
        // Creator must be in participants
        request.auth.uid in request.resource.data.participants
      );
    }

    /* =========================
       CONNECTION REQUESTS
    ========================== */
    match /requests/{requestId} {
      // 🛡️ FIX: Creator must be the fromId
      allow create: if isAuthenticated() &&
        request.resource.data.fromId == request.auth.uid;

      allow read, update: if isAuthenticated() && (
        request.auth.uid == resource.data.fromId ||
        request.auth.uid == resource.data.toId
      );
    }

    /* =========================
       CONNECTIONS
    ========================== */
    match /connections/{connectionId} {
      // For read, update, delete: check existing document
      allow read, update, delete: if isAuthenticated()
        && request.auth.uid in resource.data.participants;
      
      // For create: check the incoming document data (resource.data doesn't exist yet)
      allow create: if isAuthenticated()
        && request.auth.uid in request.resource.data.participants
        // 🛡️ FIX: Connections always have exactly 2 participants
        && request.resource.data.participants.size() == 2;
    }

    /* =========================
       NOTIFICATIONS
    ========================== */
    match /notifications/{notificationId} {
      allow read, update: if isAuthenticated()
        && resource.data.receiverId == request.auth.uid;

      // 🛡️ FIX: Restrict notification creation - sender must be authenticated user
      allow create: if isAuthenticated() &&
        request.resource.data.senderId == request.auth.uid;
    }

    /* =========================
       AUDIT / SAFETY (ADMIN)
    ========================== */
    match /audit_logs/{logId} {
      allow create: if isAuthenticated();
      allow read, update, delete: if false;
    }

    match /disconnection_logs/{logId} {
      allow create: if isAuthenticated();
      allow read, update, delete: if false;
    }

    match /safety_reports/{reportId} {
      allow create: if isAuthenticated();
      allow read, update, delete: if false;
    }

    /* =========================
       WAITLIST (Pre-Launch)
    ========================== */
    match /waitlist/{entryId} {
      // Anyone can subscribe (no auth required), must include email and college
      allow create: if request.resource.data.keys().hasAll(['email', 'college'])
        && request.resource.data.email is string
        && request.resource.data.email.size() > 0
        && request.resource.data.college is string
        && request.resource.data.college.size() > 0;

      // No read/update/delete from client
      allow read, update, delete: if false;
    }
  }
}
